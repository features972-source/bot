# Optional: copy .env.render.example values for Render cloud deploy (see RENDER.md)
# CLOUD_DEPLOYED=true
# DATA_DIR=/data
ADMIN_CHAT_ID=your_telegram_user_id
NOTIFY_CHAT_ID=your_group_chat_id
BOT_DISPLAY_NAME=Q1 Call Manager
# Optional: separate DB for this instance (default links.db)
# DATABASE_PATH=links.db
# Second instance on same PC: copy .env.bot2.example to .env.bot2, use scripts/start-second-bot.ps1
# Q1 Australia: copy .env.q1australia.example to .env.q1australia, use scripts/start-q1australia-bot.ps1
# Comma-separated Telegram user IDs allowed to use /credo (optional; admins always can)
CREDO_WHITELIST_USER_IDS=
# Quiet wins — private DMs when agents beat their own handle time or close rate (all linked users)
# Optional legacy card names (use /addcredo instead)
CREDO_CREDIT_CARDS=
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080
WEBHOOK_SECRET=change_me_to_a_random_string
# Timezone for /stats and /outstats "today" (IANA name, e.g. Europe/London)
STATS_TIMEZONE=Europe/London
# Payment display currency (default £). Q1 Australia example: A$
# PAYMENT_CURRENCY_SYMBOL=£
# Shift ready check — DM linked agents once daily (hour 0-23 local). off = manual /ready only
READY_CHECK_HOUR=9
READY_CHECK_ENABLED=true

# Full path to export file (.csv or .xlsx). CSV: flat file, no worksheet name needed.
# Excel: use a synced OneDrive path; PAYMENTS_ONEDRIVE_WORKSHEET selects the tab.
PAYMENTS_ONEDRIVE_PATH=C:\Users\You\OneDrive\q1.xlsx
# Worksheet tab for .xlsx/.xlsm only (ignored for .csv)
PAYMENTS_ONEDRIVE_WORKSHEET=Sheet1
# Excel on the web (optional — set after /excelwebauth or paste your edit link)
# EXCEL_WEB_URL=https://onedrive.live.com/edit?...
# Azure app for /excelwebauth (personal Microsoft account, redirect http://localhost:53682/)
# MS_GRAPH_CLIENT_ID=
# MS_GRAPH_CLIENT_SECRET=

# 3CX AI Call Control (automatic on/off phone announcements + admin call commands)
THREECX_FQDN=q1paym.my3cx.co.uk
THREECX_CLIENT_ID=999
THREECX_API_KEY=your_api_key_here
# Extension used by /listen fallback when live stream unavailable
THREECX_ADMIN_EXT=999
# Public HTTPS URL required for Listen in Telegram Mini App (e.g. ngrok https://xxxx.ngrok-free.app)
LISTEN_PUBLIC_URL=
# Optional: ring admin extension for phone listen (true/false — can disrupt calls, use carefully)
LISTEN_USE_PHONE_FALLBACK=
# Optional: also create named group invite link (slower — set true if you want Join room button)
LISTEN_NAMED_INVITE=
# Group where named listen invite links are created (defaults to NOTIFY_CHAT_ID)
LISTEN_CHAT_ID=
# Post call transcript to notify group after hangup (requires 3CX AI Transcription + XAPI access)
TRANSCRIPT_ENABLED=false

# Optional: Telethon userbot bridge for /mail → Q1 Mailer (keys from https://my.telegram.org)
# TELETHON_API_ID=
# TELETHON_API_HASH=
# MAILER_BOT_USERNAME=RvssianMailBot
# MAILER_DISPLAY_NAME=Q1 Mailer
# After setting keys, run once: python scripts/telethon_login.py
