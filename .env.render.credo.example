# Credo Bot — Render Web Service (cc commands only)
# Copy values into Render -> credo-telegram-bot -> Environment
# Or run: powershell -File scripts/deploy-render-credo.ps1

BOT_TOKEN=
ADMIN_CHAT_ID=
WEBHOOK_SECRET=

CLOUD_DEPLOYED=true
CREDO_ONLY_MODE=true
DATA_DIR=/data
DATABASE_PATH=/data/links-credo.db
WEBHOOK_HOST=0.0.0.0
BOT_DISPLAY_NAME=Credo Bot
BOT_INSTANCE_ID=credo
STATS_TIMEZONE=Europe/London
READY_CHECK_ENABLED=false

# Set after first deploy (or let deploy-render-credo.ps1 set it):
# LISTEN_PUBLIC_URL=https://credo-telegram-bot.onrender.com
