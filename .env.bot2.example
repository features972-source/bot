# Second bot instance — copy this file to .env.bot2 and fill in.
# Run: powershell -File scripts\start-second-bot.ps1

# REQUIRED: new bot from @BotFather (never reuse bot 1's token)
BOT_TOKEN=your_second_bot_token

ADMIN_CHAT_ID=your_telegram_user_id

# Second Telegram group/channel chat id
NOTIFY_CHAT_ID=your_second_group_chat_id

BOT_DISPLAY_NAME=Q2 Call Manager

# Separate database (payments, links, blacklist, stats)
DATABASE_PATH=links-bot2.db

# Must differ from bot 1 (default 8080) if both run on same laptop
WEBHOOK_PORT=8081
WEBHOOK_HOST=0.0.0.0
WEBHOOK_SECRET=change_me_second_random_string

STATS_TIMEZONE=Europe/London

# Q2: leave OneDrive unset (no Excel export sync)
# PAYMENTS_ONEDRIVE_PATH=
# PAYMENTS_ONEDRIVE_WORKSHEET=Sheet1

# Separate 3CX system for Q2
THREECX_FQDN=q2premium.3cx.uk
THREECX_CLIENT_ID=888
THREECX_API_KEY=your_api_key_here
THREECX_ADMIN_EXT=888

# Leave empty unless you run a second tunnel on port 8081
LISTEN_PUBLIC_URL=
LISTEN_USE_PHONE_FALLBACK=true

CREDO_WHITELIST_USER_IDS=
TRANSCRIPT_ENABLED=false
