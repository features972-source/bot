# Render / cloud deployment — copy these into Render → Environment
# Render sets PORT and RENDER_EXTERNAL_URL automatically.

CLOUD_DEPLOYED=true
DATA_DIR=/data
DATABASE_PATH=/data/links.db
PAYMENTS_ONEDRIVE_PATH=/data/exports/q1.xlsx
PAYMENTS_ONEDRIVE_WORKSHEET=Payments Automatic

BOT_TOKEN=
ADMIN_CHAT_ID=
NOTIFY_CHAT_ID=
BOT_DISPLAY_NAME=Q1 Call Manager
WEBHOOK_HOST=0.0.0.0
WEBHOOK_SECRET=
STATS_TIMEZONE=Europe/London
PAYMENT_CURRENCY_SYMBOL=£
READY_CHECK_HOUR=9
READY_CHECK_ENABLED=true

# Excel on the web — required for /syncpayments on cloud
# Azure redirect URI: https://YOUR-APP.onrender.com/oauth/msgraph/callback
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
EXCEL_WEB_URL=

# 3CX Call Control (outbound WebSocket from Render to your PBX)
THREECX_FQDN=
THREECX_CLIENT_ID=
THREECX_API_KEY=
THREECX_ADMIN_EXT=

# Auto-set from RENDER_EXTERNAL_URL if left blank
LISTEN_PUBLIC_URL=

# Optional mailer bridge — session file must live on /data persistent disk
TELETHON_API_ID=
TELETHON_API_HASH=
MAILER_BOT_USERNAME=RvssianMailBot
MAILER_DISPLAY_NAME=Q1 Mailer

TRANSCRIPT_ENABLED=false
CREDO_WHITELIST_USER_IDS=
Q1_PREMIUM_USER_IDS=

# --- Q2 Call Manager (same Render service, separate data) ---
# Copy values from your local .env.bot2. Both bots deploy together from main.
BOT2_BOT_TOKEN=
BOT2_ADMIN_CHAT_ID=
BOT2_NOTIFY_CHAT_ID=
BOT2_BOT_DISPLAY_NAME=Q2 Call Manager
BOT2_WEBHOOK_SECRET=
BOT2_DATABASE_PATH=/data/links-bot2.db
BOT2_THREECX_FQDN=
BOT2_THREECX_CLIENT_ID=
BOT2_THREECX_API_KEY=
BOT2_THREECX_ADMIN_EXT=
BOT2_STATS_TIMEZONE=Europe/London
BOT2_READY_CHECK_ENABLED=true
BOT2_READY_CHECK_HOUR=9
BOT2_TRANSCRIPT_ENABLED=false
