# Q1 Australia — copy to .env.q1australia and fill in.
# Run: powershell -File scripts\start-q1australia-bot.ps1

# REQUIRED: new bot from @BotFather (never reuse another instance's token)
BOT_TOKEN=your_q1_australia_bot_token

ADMIN_CHAT_ID=your_telegram_user_id

# Australia team Telegram group chat id
NOTIFY_CHAT_ID=your_australia_group_chat_id

BOT_DISPLAY_NAME=Q1 Australia
PAYMENT_CURRENCY_SYMBOL=A$

# Separate database (payments, links, blacklist, stats)
DATABASE_PATH=links-q1australia.db

# Must differ from Q1 (8080) and Q2 (8081) when all run on same PC
WEBHOOK_PORT=8082
WEBHOOK_HOST=0.0.0.0
WEBHOOK_SECRET=change_me_q1_australia_random_string

STATS_TIMEZONE=Australia/Sydney
READY_CHECK_HOUR=9
READY_CHECK_ENABLED=true

# No Excel export (keeps Australia outs out of UK q1.xlsx)
# PAYMENTS_ONEDRIVE_PATH=
# PAYMENTS_ONEDRIVE_WORKSHEET=Sheet1

# 3CX — separate API integration from UK (Admin → Integrations → API)
THREECX_FQDN=q1paym.my3cx.co.uk
THREECX_CLIENT_ID=your_australia_client_id
THREECX_API_KEY=your_australia_api_secret
THREECX_ADMIN_EXT=your_australia_admin_extension

LISTEN_PUBLIC_URL=
LISTEN_USE_PHONE_FALLBACK=true
TRANSCRIPT_ENABLED=false

CREDO_WHITELIST_USER_IDS=

# Telethon /mail — same mailer as Q1 UK (separate session file per database)
TELETHON_API_ID=28849027
TELETHON_API_HASH=your_telethon_api_hash
MAILER_BOT_USERNAME=RvssianMailBot
MAILER_DISPLAY_NAME=Q1 Mailer
