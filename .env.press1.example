# Press-1 bot — Render env vars for credo-telegram-bot service

BOT_TOKEN=your-telegram-bot-token
TELEGRAM_ALLOWED_IDS=123456789

# SSH to VICIdial server (paste full private key; use \n for newlines on Render)
VICIDIAL_SSH_HOST=206.189.118.204
VICIDIAL_SSH_USER=root
VICIDIAL_SSH_KEY=-----BEGIN OPENSSH PRIVATE KEY-----\n...\n-----END OPENSSH PRIVATE KEY-----

VICIDIAL_CAMPAIGN=press1
VICIDIAL_LIST_ID=101
VICIDIAL_SOUND_NAME=press1_alice
VICIDIAL_SERVER_IP=206.189.118.204
VICIDIAL_MAX_CONCURRENT=0
VICIDIAL_DIALER_CAP=0
VICIDIAL_CALL_GAP_SEC=0.05
VICIDIAL_CPS=10
# Seconds to wait for digit after IVR greeting ends (lower = cheaper on voicemail/no-press)
PRESS1_IVR_DIGIT_TIMEOUT=8
# Default country for bare numbers in CSV (64=NZ, 44=UK, 61=AU)
PRESS1_DEFAULT_PHONE_CODE=64
# Optional NZ CLI from BitCall (falls back to VICIDIAL_CALLER_ID if unset)
# VICIDIAL_NZ_CALLER_ID=642XXXXXXXX
# UK outbound CLI — random per call from 020 / 080 / 0330 only (never 07 mobiles)
# Comma-separate multiple numbers per type if BitCall authorized more than one
VICIDIAL_UK_CLI_020=442038968062,442038969244
VICIDIAL_UK_CLI_0330=443308222183
# VICIDIAL_UK_CLI_080=448001234567
# VICIDIAL_UK_CLI_LIST=442039960793,443375988997
VICIDIAL_TEST_NUMBERS=447769799593
PRESS1_OWNER_TEST_NUMBER=447769799593
