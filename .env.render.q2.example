# Render — Q2 Call Manager (separate Web Service from Q1)
# Copy values from your local .env.bot2 into Render → Environment.
# Q2 needs its OWN bot token, group id, 3CX keys, disk, and Render URL.

CLOUD_DEPLOYED=true
DATA_DIR=/data
DATABASE_PATH=/data/links-bot2.db
PAYMENTS_ONEDRIVE_PATH=/data/exports/q2.xlsx
PAYMENTS_ONEDRIVE_WORKSHEET=Sheet1

BOT_TOKEN=
ADMIN_CHAT_ID=
NOTIFY_CHAT_ID=
BOT_DISPLAY_NAME=Q2 Call Manager
WEBHOOK_HOST=0.0.0.0
WEBHOOK_SECRET=
STATS_TIMEZONE=Europe/London
PAYMENT_CURRENCY_SYMBOL=£
READY_CHECK_HOUR=9
READY_CHECK_ENABLED=true

# After deploy, set to your Q2 Render URL (e.g. https://q2-telegram-bot.onrender.com)
LISTEN_PUBLIC_URL=

# Q2 3CX system (different from Q1)
THREECX_FQDN=
THREECX_CLIENT_ID=
THREECX_API_KEY=
THREECX_ADMIN_EXT=

# Optional — same as Q1 if you use mailer on Q2
TELETHON_API_ID=
TELETHON_API_HASH=
MAILER_BOT_USERNAME=RvssianMailBot
MAILER_DISPLAY_NAME=Q1 Mailer

TRANSCRIPT_ENABLED=false
CREDO_WHITELIST_USER_IDS=
